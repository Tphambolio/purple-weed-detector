# Local dev configuration. Copy to .env.local and fill in.
# .env.local is gitignored — never commit real keys.

# ── Direct mode (Phase 1, no proxy) ────────────────────────────────────
# Embeds the Gemini key in the bundle. ONLY use for local dev with
# `npm run dev`. Never set this in a production build.
VITE_GEMINI_API_KEY=

# ── Proxy mode ────────────────────────────────────────────────────────
# Switch the client to proxy mode. The Gemini key never reaches the
# browser; the server-side proxy holds it.
VITE_USE_PROXY=

# Full URL of the deployed proxy endpoint. Examples:
#   GCP Cloud Function: https://<region>-<project>.cloudfunctions.net/gemini-proxy
#   GCP Cloud Run:      https://gemini-proxy-<hash>.<region>.run.app
# If unset, the client falls back to https://purple-weed-detector.pages.dev/api/gemini
# so existing local-dev workflows keep working without any changes.
VITE_API_BASE_URL=
